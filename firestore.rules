rules_version = '2';

// Security rules for the `zajil` named Firestore database.
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{uid} {
      // Any signed-in user may read profiles. `read` covers both single-doc
      // gets (getUserProfile) and collection queries (isUsernameAvailable,
      // which lists `users` filtered by username).
      allow read: if request.auth != null;

      // A user may create or modify only their own profile document.
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
